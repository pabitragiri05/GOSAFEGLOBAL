# GoSafe Global – Environment Variables Template
# ================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore.
#
# On Vercel: add these in Project Settings → Environment Variables

# Gmail address used to SEND chatbot notification emails
GOSAFE_SENDER_EMAIL=your-gmail@gmail.com

# Gmail App Password (NOT your login password).
# Generate one at: https://myaccount.google.com/apppasswords
GOSAFE_SENDER_PASSWORD=xxxx xxxx xxxx xxxx

# Email address where all chatbot leads are delivered
# (can be same as SENDER_EMAIL, or a separate inbox)
GOSAFE_RECIPIENT_EMAIL=your-recipient@gmail.com
