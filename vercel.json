{
  "version": 2,
  "name": "gosafe-global",
  "env": {
    "GOSAFE_SENDER_EMAIL": "@gosafe-sender-email",
    "GOSAFE_SENDER_PASSWORD": "@gosafe-sender-password",
    "GOSAFE_RECIPIENT_EMAIL": "@gosafe-recipient-email"
  },
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
